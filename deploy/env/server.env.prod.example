# agent-forge production env — install at /etc/agent-forge/server.env
# Permissions: chown root:agentforge, chmod 0640  (readable only by the service user)

APP_ENV=prod
# generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=__REPLACE_WITH_48+_CHAR_RANDOM__

# managed Postgres (real host + strong password, NOT the dev default)
DATABASE_URL=postgresql+asyncpg://agentforge:__DB_PASSWORD__@127.0.0.1:5432/agentforge
SYNC_DATABASE_URL=postgresql+psycopg://agentforge:__DB_PASSWORD__@127.0.0.1:5432/agentforge

REDIS_URL=redis://127.0.0.1:6379/0

# LLM gateway (camel-hub) — the API key is a SECRET; keep it only in this 0640 file
LLM_BASE_URL=https://api.camel-hub.com/v1
LLM_API_KEY=__CAMEL_HUB_KEY__
PLLM_MODEL=claude-sonnet-4-5
QLLM_MODEL=claude-haiku-4-5

# exact browser origins (no '*', credentials are sent)
CORS_ORIGINS=https://agent-forge.example.com

# observability
LOG_DIR=/var/log/agent-forge
LOG_LEVEL=INFO
LOG_JSON=true

# auth — demo role-login MUST be off in prod
DEMO_LOGIN=false
SESSION_TTL_DAYS=7

# gunicorn
API_BIND=127.0.0.1:8099
WEB_CONCURRENCY=5
